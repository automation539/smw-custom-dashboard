NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose to the browser. Only needed once background GHL
# sync jobs are implemented (bypasses RLS via the service_role key).
SUPABASE_SERVICE_ROLE_KEY=

# Server-only. Authenticates requests to /api/cron/sync (checked against
# the "Authorization: Bearer <value>" header). Generate a random value, e.g.
# `openssl rand -hex 32`, and set the same value in Vercel's project env vars.
CRON_SECRET=
